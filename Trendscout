version: "3.9"

services:
  postgres:
    image: pgvector/pgvector:pg16
    container_name: trendscout_db
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-trendscout}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-trendscout_pass}
      POSTGRES_DB: ${POSTGRES_DB:-trendscout}
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
      - ./backend/init.sql:/docker-entrypoint-initdb.d/init.sql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U trendscout"]
      interval: 5s
      timeout: 5s
      retries: 5

  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: trendscout_backend
    env_file: .env
    ports:
      - "8000:8000"
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - ./backend:/app
    command: uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: trendscout_frontend
    env_file: .env
    ports:
      - "3000:3000"
    depends_on:
      - backend
    environment:
      - NEXT_PUBLIC_API_URL=http://localhost:8000

volumes:
  pgdata:
